  // ══════════════════════════════════════════════════════════════════
  // ⚠️  MANEJO DE ERRORES
  // ══════════════════════════════════════════════════════════════════
  {
    id: 'errors', icon: '⚠️',
    title: 'Manejo de Errores',
    desc:  'Validaciones, 404s y seguridad de tokens',
    tests: [
      {
        id: '404-usuario', method: 'GET', path: '/api/Usuarios/99999', auth: true,
        name: 'GET /api/Usuarios/99999 → 404',
        desc: 'ID inexistente debe devolver 404',
        expect: { status: 404 },
        hint: 'El controller debe retornar NotFound() cuando el servicio no encuentra el registro.'
      },
      {
        id: '404-proyecto', method: 'GET', path: '/api/proy/proyectos/99999', auth: true,
        name: 'GET /api/proy/proyectos/99999 → 404',
        desc: 'Proyecto inexistente debe devolver 404',
        expect: { status: 404 }
      },
      {
        id: '404-empleado', method: 'GET', path: '/api/rrhh/empleados/99999', auth: true,
        name: 'GET /api/rrhh/empleados/99999 → 404',
        desc: 'Empleado inexistente debe devolver 404',
        expect: { status: 404 }
      },
      {
        id: '404-catalogo', method: 'GET', path: '/api/catalogos/paises/99999', auth: true,
        name: 'GET /api/catalogos/paises/99999 → 404',
        desc: 'País inexistente debe devolver 404',
        expect: { status: 404 }
      },
      {
        id: 'login-empty', method: 'POST', path: '/api/Auth/login', auth: false,
        name: 'POST /api/Auth/login vacío → 400',
        desc: 'Campos vacíos deben devolver 400 con errores de validación',
        body: { email: '', password: '' },
        expect: { status: 400 },
        hint: 'FluentValidation debe rechazar el request antes de llegar al servicio.'
      },
      {
        id: 'invalid-token', method: 'GET', path: '/api/Usuarios', auth: false,
        name: 'GET /api/Usuarios con JWT inválido → 401',
        desc: 'Token manipulado debe ser rechazado',
        expect: { status: 401 },
        _fakeToken: 'eyJhbGciOiJIUzI1NiJ9.FAKE.INVALID',
        hint: 'El middleware JWT debe rechazar tokens inválidos con 401.'
      },
      {
        id: 'bad-refresh', method: 'POST', path: '/api/Auth/refresh-token', auth: false,
        name: 'POST /api/Auth/refresh-token con token falso → error',
        desc: 'Refresh token inválido debe ser rechazado con 400 o 401',
        body: { Token: 'token-falso-12345' },   // backend espera campo "Token" (no "RefreshToken")
        expect: { status: [400, 401] },
        hint: 'El servicio de auth debe validar el refreshToken contra la BD.'
      }
    ]
  }

];
