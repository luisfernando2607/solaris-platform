            return items.length > 0;
          },
          checkDesc: 'array de usuarios no vacío'
        },
        hint: 'Verificar datos semilla en la BD.'
      },
      {
        id: 'get-usuario', method: 'GET', path: `/api/Usuarios/${SEED.usuarioId}`, auth: true,
        name: `GET /api/Usuarios/${SEED.usuarioId} — por ID`,
        desc: 'Espera: HTTP 200',
        expect: { status: 200 }
      }
    ]
  },

