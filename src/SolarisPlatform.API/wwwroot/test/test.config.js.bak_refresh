      { id: 'presupuesto-activo',  method: 'GET', path: `/api/proy/proyectos/${SEED.proyectoId}/presupuesto/activo`,            auth: true, name: 'GET proyecto/presupuesto/activo',            desc: 'Espera: HTTP 200 o 404 si no hay activo', expect: { status: [200, 404] } },
