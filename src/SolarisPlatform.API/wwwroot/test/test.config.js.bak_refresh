// ══════════════════════════════════════════════════════════════════════
//  test.config.js  —  Solaris Platform · API Test Console
//  ─────────────────────────────────────────────────────────────────────
//  ÚNICA FUENTE DE VERDAD — sincronizado con swagger v1 (2026-03-06)
//
//  Para agregar un endpoint nuevo:
//    1. Localiza la suite correcta (o agrega una nueva al final).
//    2. Agrega un objeto al array "tests" de esa suite.
//    3. Nada más.
//
//  Ajusta las constantes SEED si los IDs de tus datos semilla cambian.
//
//  Estructura de un test:
//  {
//    id:           string  — identificador único (slug, sin espacios)
//    name:         string  — descripción corta visible en la UI
//    desc:         string  — descripción del comportamiento esperado
//    method:       'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE'
//    path:         string  — ruta relativa a baseUrl  ej: '/api/Usuarios'
//    auth:         boolean — true = enviar JWT en Authorization header
//    body?:        object | '__USE_CREDS__' | '__USE_REFRESH__' | null
//    expect: {
//      status:       number | number[]  — HTTP status(es) aceptados
//      check?:       (data) => boolean  — validación adicional del body
//      checkDesc?:   string             — descripción legible del check
//    }
//    hint?:        string  — pista mostrada cuando el test falla
//    _fakeToken?:  string  — token falso (para tests de seguridad)
//  }
//
//  Cuerpos especiales:
//    '__USE_CREDS__'   → { email, password } tomados de los inputs del UI
//    '__USE_REFRESH__' → { RefreshToken } tomado del token capturado en login
// ══════════════════════════════════════════════════════════════════════

// ── IDs de datos semilla ────────────────────────────────────────────
const SEED = {
  proyectoId:    1,
  empleadoId:    1,
  faseId:        1,
  hitoId:        1,
  wbsId:         1,
  tareaId:       1,
  cuadrillaId:   1,
  otId:          1,
  reporteId:     1,
  presupuestoId: 1,
  ccId:          1,
  alertaId:      1,
  empresaId:     1,
  sucursalId:    1,
  usuarioId:     1,
  rolId:         1,
  paisId:        1,
  estadoId:      1,
  ciudadId:      1,
  monedaId:      1,
  tipoIdId:      1,
  impuestoId:    1,
  formaPagoId:   1,
  bancoId:       1,
  departamentoId:1,
  puestoId:      1,
  nominaId:      1,
  conceptoId:    1,
  paisCodigo:   'EC',
  anno:          2025,
};

const TEST_SUITES = [

  // ══════════════════════════════════════════════════════════════════
  // 🔍  SMOKE — ¿La API está viva?
  // ══════════════════════════════════════════════════════════════════
  {
    id: 'smoke', icon: '🔍',
    title: 'Smoke Tests',
    desc:  'Verificar que la API responde sin autenticación',
    tests: [
      {
        id: 'health-api', method: 'GET', path: '/health/api', auth: false,
        name: 'GET /health/api — API responde',
        desc: 'Espera: status=Healthy, HTTP 200',
        expect: { status: 200, check: d => d?.status === 'Healthy', checkDesc: 'body.status === "Healthy"' }
      },
      {
        id: 'health-data', method: 'GET', path: '/health/data', auth: false,
        name: 'GET /health/data — API + BD responden',
        desc: 'Espera: status=Healthy y BD conectada',
        expect: {
          status: 200,
          check: d => d?.checks?.find(c => c.name === 'database')?.status === 'Healthy',
          checkDesc: 'checks[database].status === "Healthy"'
        }
      },
      {
        id: 'health-db', method: 'GET', path: '/health/db', auth: false,
        name: 'GET /health/db — solo BD',
        desc: 'Espera: HTTP 200, BD conectada',
        expect: { status: 200, check: d => d?.status === 'Healthy', checkDesc: 'body.status === "Healthy"' }
      },
      {
        id: 'api-info', method: 'GET', path: '/api/info', auth: false,
        name: 'GET /api/info — info de la API',
        desc: 'Espera: HTTP 200',
        expect: { status: 200 }
      },
      {
        id: 'unauth', method: 'GET', path: '/api/Usuarios', auth: false,
        name: 'GET /api/Usuarios sin JWT → 401',
        desc: 'Espera: HTTP 401 Unauthorized',
        expect: { status: 401 },
        hint: 'Verificar [Authorize] en UsuariosController.'
      }
    ]
  },

  // ══════════════════════════════════════════════════════════════════
  // 🔑  AUTH — Login, JWT, refresh token, logout
  // ══════════════════════════════════════════════════════════════════
  {
    id: 'auth', icon: '🔑',
    title: 'Autenticación',
    desc:  'Login, JWT, refresh token, logout',
    tests: [
      {
        id: 'login-bad', method: 'POST', path: '/api/Auth/login', auth: false,
        name: 'POST /api/Auth/login — credenciales incorrectas → 400/401',
        desc: 'Espera: error, sin token',
        body: { email: 'malo@test.com', password: 'ContraseñaMala123!' },
        expect: { status: [400, 401] },
        hint: 'Login inválido debe retornar 400 o 401, nunca 200.'
      },
      {
        id: 'login-ok', method: 'POST', path: '/api/Auth/login', auth: false,
        name: 'POST /api/Auth/login — credenciales correctas → 200 + JWT',
        desc: 'Espera: HTTP 200 con token JWT',
        body: '__USE_CREDS__',
        expect: {
          status: 200,
          check: d => !!(d?.data?.token || d?.token || d?.accessToken),
          checkDesc: 'response contiene token JWT'
        },
        hint: 'Verificar email/password en los inputs. Token esperado en data.token o data.data.token.'
      },
      {
        id: 'me', method: 'GET', path: '/api/Auth/me', auth: true,
        name: 'GET /api/Auth/me — perfil autenticado',
        desc: 'Espera: HTTP 200 con datos del usuario',
        expect: {
          status: 200,
          check: d => !!(d?.data?.email || d?.email),
          checkDesc: 'response contiene email del usuario'
        }
      },
      {
        id: 'refresh', method: 'POST', path: '/api/Auth/refresh-token', auth: false,
        name: 'POST /api/Auth/refresh-token — renovar JWT',
        desc: 'Espera: HTTP 200 con nuevo token',
        body: '__USE_REFRESH__',   // runner enviará { Token: refreshToken } — backend espera "Token" no "RefreshToken"
        expect: {
          status: 200,
          check: d => !!(d?.data?.token || d?.data?.accessToken || d?.token || d?.accessToken),
          checkDesc: 'response contiene nuevo token'
        }
      },
      {
        id: 'logout', method: 'POST', path: '/api/Auth/logout', auth: true,
        name: 'POST /api/Auth/logout — cerrar sesión',
        desc: 'Espera: HTTP 200',
        expect: { status: 200 }
      }
    ]
  },

  // ══════════════════════════════════════════════════════════════════
